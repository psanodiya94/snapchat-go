# Copy to .env and fill in your values
PORT=8080

# PostgreSQL connection (choose one approach)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/snapchat?sslmode=disable
# -- OR use individual vars:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=snapchat

# Change this to a long random string in production
JWT_SECRET=change-me-in-production
